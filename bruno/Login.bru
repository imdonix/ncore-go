meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/login
  body: json
  auth: none
}

body:json {
  {
    "username": "{{username}}",
    "password": "{{password}}",
    "2factor": "{{twoFactor}}"
  }
}

script:post-response {
  const data = res.getBody();
  if (data && data.token) {
    bru.setVar("token", data.token);
  }
}
