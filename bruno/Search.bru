meta {
  name: Search
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/search
  body: json
  auth: none
}

headers {
  X-Ncore-Auth: {{token}}
}

body:json {
  {
    "pattern": "Forrest Gump",
    "type": "hd_hun",
    "where": "name",
    "sort_by": "seeders",
    "sort_order": "DESC",
    "page": 1
  }
}
